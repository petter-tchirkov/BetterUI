<GuiXml>
    <!--
    File: Modules/CIM/Templates/GenericFooter.xml
    Purpose: Defines the virtual controls for the bottom bar (Footer).
             Includes labels for Bag/Bank capacity and all supported currencies.
             Note: Currently primarily used by the Inventory/Banking modules.
    -->
    <Controls>

        <!-- Template for Footer Labels (Uppercase) -->
        <Label name="BETTERUI_GamepadScreenFooterTemplate" font="ZoFontGamepad27"
            horizontalAlignment="LEFT" wrapMode="ELLIPSIS" virtual="true" modifyTextType="UPPERCASE" />

        <!-- Anchoring Helper -->
        <Control name="BETTERUI_GamepadFooterAnchors" virtual="true">
            <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT" />
            <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT" />
        </Control>

        <!-- 
            Template: Horizontal Divider (Footer style)
            Similar to Header divider but usage context differs.
        -->
        <Control name="BETTERUI_GamepadFooterHorizontalDivider" resizeToFitDescendents="true"
            virtual="true">
            <Controls>
                <Texture name="$(parent)Left"
                    textureFile="EsoUI/Art/Windows/Gamepad/gp_nav1_horDivider.dds">
                    <Anchor point="LEFT" />
                    <Dimensions x="0" y="BETTERUI_DIVIDER_HEIGHT" />
                    <TextureCoords left="0" right="0.29296875" top="0" bottom="1" />
                </Texture>

                <Texture name="$(parent)Right"
                    textureFile="EsoUI/Art/Windows/Gamepad/gp_nav1_horDivider.dds">
                    <Anchor point="RIGHT" />
                    <Dimensions x="0" y="8" />
                    <TextureCoords left="0.70703125" right="1" top="0" bottom="1" />
                </Texture>

                <Texture name="$(parent)Center"
                    textureFile="EsoUI/Art/Windows/Gamepad/gp_nav1_horDivider.dds">
                    <Anchor point="TOPLEFT" relativeTo="$(parent)Left" relativePoint="TOPRIGHT" />
                    <Anchor point="BOTTOMRIGHT" relativeTo="$(parent)Right"
                        relativePoint="BOTTOMLEFT" />
                    <TextureCoords left="0.29296875" right="0.70703125" top="0" bottom="1" />
                </Texture>
            </Controls>
        </Control>

        <!-- 
            Template: Generic Screen Footer
            The actual container with all label controls defined.
        -->
        <Control name="BETTERUI_GamepadGenericScreenFooter" inherits="BETTERUI_GamepadFooterAnchors"
            resizeToFitDescendents="false" virtual="true">
            <Anchor point="BOTTOMLEFT" relativeTo="$(parent)"
                offsetY="BETTERUI_FOOTER_BOTTOM_OFFSET_Y" />
            <Anchor point="BOTTOMRIGHT" relativeTo="$(parent)"
                offsetY="BETTERUI_FOOTER_BOTTOM_OFFSET_Y" />

            <Controls>
                <Control name="$(parent)DividerBottom"
                    inherits="BETTERUI_GamepadFooterHorizontalDivider">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="0" />
                    <Anchor point="RIGHT" relativeTo="$(parent)" relativePoint="BOTTOMRIGHT"
                        offsetX="0"
                        offsetY="BETTERUI_FOOTER_DIVIDER_OFFSET_Y" />
                </Control>

                <!-- 
                    Currency Labels
                    All labels are created here but hidden/positioned dynamically by GenericFooter.lua
                -->
                <Label name="$(parent)CWLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_CARRY">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="0" offsetY="32" />
                </Label>
                <Label name="$(parent)GoldLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_GOLD">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="200" offsetY="32" />
                </Label>
                <Label name="$(parent)KeysLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_KEYS">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="450" offsetY="32" />
                </Label>
                <Label name="$(parent)TCLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_CRYSTALS">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="700" offsetY="32" />
                </Label>
                <Label name="$(parent)CrownsLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_CROWNS">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="950" offsetY="32" />
                </Label>
                <Label name="$(parent)GemsLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_GEMS">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="1150" offsetY="32" />
                </Label>
                <Label name="$(parent)BankLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_BANK">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="0" offsetY="58" />
                </Label>
                <Label name="$(parent)TVLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_TELVAR">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="200" offsetY="58" />
                </Label>
                <Label name="$(parent)APLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_AP">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="450" offsetY="58" />
                </Label>
                <Label name="$(parent)WritsLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_WRITS">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="700" offsetY="58" />
                </Label>
                <Label name="$(parent)TradeBarsLabel"
                    inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_TRADE_BARS">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="950" offsetY="58" />
                </Label>
                <Label name="$(parent)OutfitLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_OUTFIT_TOKENS">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="1150" offsetY="58" />
                </Label>
                <!-- Seals (formerly Endeavor Seals) -->
                <Label name="$(parent)SealsLabel" inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_SEALS">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="200" offsetY="84" />
                </Label>
                <!-- Tome Points (Tamriel Tomes system) -->
                <Label name="$(parent)TomePointsLabel"
                    inherits="BETTERUI_GamepadScreenFooterTemplate"
                    text="SI_BETTERUI_FOOTER_TOME_POINTS">
                    <Anchor point="LEFT" relativeTo="$(parent)" relativePoint="BOTTOMLEFT"
                        offsetX="450" offsetY="84" />
                </Label>

            </Controls>
        </Control>

        <!-- Template Wrapper for Footer -->
        <Control name="BETTERUI_GamepadScreenFooterContainer" virtual="true">
            <Dimensions y="40" />
            <Controls>
                <Control name="$(parent)Footer" inherits="BETTERUI_GamepadGenericScreenFooter">
                    <OnInitialized>
                        self:GetParent().footer = self
                    </OnInitialized>
                </Control>
            </Controls>
        </Control>

    </Controls>
</GuiXml>