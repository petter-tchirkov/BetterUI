<GuiXml>
    <!--
    File: Modules/CIM/Templates/SharedTemplates.xml
    Purpose: Defines virtual UI templates (classes) for the Gamepad Interface.
             These templates describe List Entries (Rows), Icons, and Labels.
             Inherited by specific controls in Inventory, Banking, and Writ modules.
    Naming Standard: BETTERUI_Gamepad*
    -->
    <Controls>

        <!-- 
            Template: Label
            Purpose: Standard text label for list entries.
            Structure: A generic label using Gamepad Font 34 (Medium-Large), elliptically wrapped.
                       Used as the base for most simple list text.
            References: Used in GamepadMenuEntryTemplate and SubMenuEntryTemplate.
        -->
        <Label name="BETTERUI_GamepadSubMenuEntryLabelTemplate" font="ZoFontGamepad34"
            verticalAlignment="CENTER" wrapMode="ELLIPSIS" virtual="true">
            <Anchor point="TOPLEFT" offsetX="BETTERUI_GAMEPAD_DEFAULT_LIST_ENTRY_INDENT" />
            <Dimensions x="BETTERUI_GAMEPAD_DEFAULT_LIST_ENTRY_WIDTH_AFTER_INDENT" />
        </Label>

        <!-- 
            Template: Cooldown
            Purpose: Overlay for items with cooldowns (e.g. potions, siege).
            Structure: Inherits ZO_DefaultCooldown, fills parent.
        -->
        <Cooldown name="BETTERUI_GamepadMenuEntryCooldownTemplate" inherits="ZO_DefaultCooldown"
            excludeFromResizeToFitExtents="true" pixelRoundingEnabled="false" virtual="true">
            <AnchorFill />
        </Cooldown>

        <!-- 
            Template: Status Indicator
            Purpose: Small icon for status flags: New, Stolen, Quest Item.
            Structure: Positioned 2px left of the main icon.
        -->
        <Texture name="BETTERUI_GamepadMenuEntryStatusIndicationTemplate" inherits="ZO_MultiIcon"
            excludeFromResizeToFitExtents="true" hidden="true" virtual="true">
            <Dimensions x="BETTERUI_ICON_SIZE_MEDIUM" y="BETTERUI_ICON_SIZE_MEDIUM" />
            <Anchor point="RIGHT" relativeTo="$(parent)Icon" relativePoint="LEFT"
                offsetX="BETTERUI_STATUS_INDICATOR_OFFSET_X" />
        </Texture>


        <!-- 
            Template: Main Icon
            Purpose: The primary visual representation of the item.
            Structure: Centered vertically relative to the label, to the left.
                       Contains a Highlight texture for selection state.
        -->
        <Texture name="BETTERUI_GamepadMenuEntryIconTemplate" tier="MEDIUM" inherits="ZO_MultiIcon"
            excludeFromResizeToFitExtents="true" level="1" pixelRoundingEnabled="true"
            virtual="true">
            <Dimensions x="BETTERUI_ICON_SIZE_MEDIUM" y="BETTERUI_ICON_SIZE_MEDIUM" />
            <Anchor point="CENTER" relativeTo="$(parent)Label" relativePoint="LEFT"
                offsetX="BETTERUI_GAMEPAD_DEFAULT_LIST_ENTRY_ICON_X_OFFSET" />
            <Controls>
                <Texture name="$(parent)Highlight" pixelRoundingEnabled="false" level="0">
                    <AnchorFill />
                </Texture>
            </Controls>
        </Texture>

        <!-- 
            Template: Label (Uppercase)
            Purpose: Variation of the standard label that enforces uppercase text.
            Structure: Same as SubMenuEntryLabel but with modifyTextType="UPPERCASE".
        -->
        <Label name="BETTERUI_GamepadMenuEntryLabelTemplate" font="ZoFontGamepadSub34"
            verticalAlignment="CENTER" wrapMode="ELLIPSIS" modifyTextType="UPPERCASE" virtual="true">
            <Anchor point="TOPLEFT" offsetX="BETTERUI_GAMEPAD_DEFAULT_LIST_ENTRY_INDENT" />
            <Dimensions x="BETTERUI_GAMEPAD_DEFAULT_LIST_ENTRY_WIDTH_AFTER_INDENT" />
        </Label>

        <!-- 
            Template: Component Sizing
            Purpose: Defines the root dimensions of a list entry row.
            Structure: A control containing a spacer to enforce minimum width/height.
        -->
        <Control name="BETTERUI_GamepadMenuEntryDimensionsTemplate" resizeToFitDescendents="true"
            virtual="true">
            <Controls>
                <!-- Spacer ensures the control maintains minimum width/height -->
                <Control name="$(parent)RootSpacer">
                    <Anchor point="TOPLEFT" />
                    <Dimensions x="BETTERUI_GAMEPAD_DEFAULT_LIST_ENTRY_WIDTH" y="4" />
                </Control>
            </Controls>
        </Control>

        <!-- 
            Template: Dynamic Sizing
            Purpose: Logic to calculate the height of a row based on its text content.
            Structure: Attaches an OnInitialized handler that overrides GetHeight.
                       Calculates height based on Label and ItemType children.
        -->
        <Control name="BETTERUI_GamepadMenuEntryLabelSizedTemplate" virtual="true">
            <OnInitialized>
                ZO_SharedGamepadEntry_OnInitialized(self)
                local itemTypeControl = self:GetNamedChild("ItemType")
                local function ComputeHeightFromLabelAndItemType(control)
                local height = control.label:GetTextHeight()
                if itemTypeControl then
                local typeHeight = itemTypeControl:GetTextHeight()
                height = height > typeHeight and height or typeHeight
                end
                return height
                end
                self.GetHeight = ComputeHeightFromLabelAndItemType
            </OnInitialized>
        </Control>


        <!-- 
            Template: Sub-Menu Entry (Grid Row)
            Purpose: The main template for inventory rows in BetterUI's grid view.
            Structure:
                - Label: Item Name
                - Icon: Item Icon
                - EquippedMain: Equipped lock icon
                - StatusIndicator: New/Stolen icon
                - PlayerLockedIcon
                - Columns: ItemType, Trait, Stat, Value (Labels)
            References: Inherited by detailed list rows in Inventory, Banking, and Vendor lists.
        -->
        <Control name="BETTERUI_GamepadSubMenuEntryTemplate"
            inherits="BETTERUI_GamepadMenuEntryDimensionsTemplate BETTERUI_GamepadMenuEntryLabelSizedTemplate"
            virtual="true">
            <Anchor point="TOPLEFT" offsetX="BETTERUI_GAMEPAD_CONTAINER_HORIZ_PADDING" />
            <Dimensions x="BETTERUI_GAMEPAD_DEFAULT_LIST_ENTRY_WIDTH" />
            <Controls>
                <!-- 
                    Selection Bar (Native XML Gradient)
                    Purpose: Gradient highlight for selected rows (transparent left → gold right).
                    Structure: Single texture with FadeGradient element to define gradient at
                               control creation time. Avoids Lua timing issues.
                               Gold color (#C4A64D ≈ 196,166,77) applied via color attribute.
                               FadeGradient creates left→right alpha fade effect.
                               Initially hidden, shown by SelectionHighlight.lua.
                -->
                <Texture name="$(parent)SelectionBar" tier="LOW" level="1" hidden="true"
                    color="C4A64D" alpha="0.45"
                    excludeFromResizeToFitExtents="true">
                    <!-- Explicit anchors with vertical offsets to make bar taller (captures more of
                    icon) -->
                    <!-- Negative top offset = extends above row; positive bottom offset = extends
                    below; positive right offset = extends past value column -->
                    <Anchor point="TOPLEFT" offsetY="-4" />
                    <Anchor point="BOTTOMRIGHT" offsetX="33" offsetY="4" />
                    <!-- FadeGradient: x1=1 means fade from left edge, size1=fade width in pixels -->
                    <FadeGradient x1="1" y1="0" size1="1400" x2="-1" y2="0" size2="0" />
                </Texture>


                <Label name="$(parent)Label" inherits="BETTERUI_MenuEntryLabelTemplate"
                    font="ZoFontGamepad42" wrapMode="WRAP">
                    <Anchor point="TOPLEFT" offsetX="BETTERUI_SUBMENU_LABEL_OFFSET_X" />
                    <Dimensions x="BETTERUI_SUBMENU_LABEL_WIDTH" />
                </Label>
                <Texture name="$(parent)Icon" inherits="BETTERUI_MenuEntryIconTemplate"
                    edgeColor="00000000">
                </Texture>

                <!-- Icon indicating the item is currently equipped -->
                <Texture name="$(parent)EquippedMain"
                    textureFile="BetterUI/Templates/Images/inv_equip.dds"
                    excludeFromResizeToFitExtents="true" pixelRoundingEnabled="false">
                    <Dimensions x="28" y="BETTERUI_ICON_SIZE_MEDIUM" />
                    <Anchor point="RIGHT" relativeTo="$(parent)Icon" relativePoint="LEFT"
                        offsetX="BETTERUI_EQUIPPED_ICON_OFFSET_X" />
                </Texture>

                <Texture name="$(parent)StatusIndicator"
                    inherits="BETTERUI_GamepadMenuEntryStatusIndicationTemplate" />

                <Texture name="$(parent)PlayerLockedIcon"
                    inherits="ZO_GamepadMenuEntryPlayerLockedTemplate" />

                <!-- Selection indicator for multi-select mode -->
                <Texture name="$(parent)SelectionIndicator"
                    textureFile="EsoUI/Art/Buttons/Gamepad/gp_check.dds"
                    hidden="true" pixelRoundingEnabled="false" excludeFromResizeToFitExtents="true">
                    <Dimensions x="32" y="32" />
                    <Anchor point="RIGHT" relativeTo="$(parent)Value" relativePoint="RIGHT"
                        offsetX="24" />
                </Texture>

                <!-- 
                    Column Data Labels
                    These offsets are defined in BetterUI.CONST.lua
                -->
                <Label name="$(parent)ItemType" inherits="BETTERUI_GamepadSubMenuEntryLabelTemplate"
                    text="NONE" font="ZoFontGamepadCondensed25" override="true"
                    verticalAlignment="CENTER" horizontalAlignment="LEFT"
                    excludeFromResizeToFitExtents="true">
                    <Anchor point="LEFT" relativeTo="$(parent)Label"
                        offsetX="BETTERUI_ITEM_TYPE_OFFSET_X" />
                    <Dimensions x="BETTERUI_ITEM_TYPE_WIDTH" />
                </Label>
                <Label name="$(parent)Trait" inherits="BETTERUI_GamepadSubMenuEntryLabelTemplate"
                    text="-" font="ZoFontGamepadCondensed25" override="true"
                    verticalAlignment="CENTER" horizontalAlignment="LEFT"
                    excludeFromResizeToFitExtents="true">
                    <Anchor point="LEFT" relativeTo="$(parent)Label"
                        offsetX="BETTERUI_TRAIT_OFFSET_X" />
                    <Dimensions x="BETTERUI_TRAIT_WIDTH" />
                </Label>
                <Label name="$(parent)Stat" inherits="BETTERUI_GamepadSubMenuEntryLabelTemplate"
                    text="-" font="ZoFontGamepadCondensed25" override="true"
                    verticalAlignment="CENTER" horizontalAlignment="LEFT"
                    excludeFromResizeToFitExtents="true">
                    <Anchor point="LEFT" relativeTo="$(parent)Label"
                        offsetX="BETTERUI_STAT_OFFSET_X" />
                    <Dimensions x="BETTERUI_STAT_WIDTH" />
                </Label>
                <Label name="$(parent)Value" inherits="BETTERUI_GamepadSubMenuEntryLabelTemplate"
                    text="0" font="ZoFontGamepadCondensed25" override="true"
                    verticalAlignment="CENTER" horizontalAlignment="LEFT"
                    excludeFromResizeToFitExtents="true">
                    <Anchor point="LEFT" relativeTo="$(parent)Label"
                        offsetX="BETTERUI_VALUE_OFFSET_X" />
                    <Dimensions x="BETTERUI_VALUE_WIDTH" />
                </Label>
            </Controls>
        </Control>

        <!-- Template for items with cooldowns (inherits from above) -->
        <Control name="BETTERUI_GamepadItemSubEntryTemplate"
            inherits="BETTERUI_GamepadSubMenuEntryTemplate" virtual="true">
            <Controls>
                <Cooldown name="$(parent)Cooldown"
                    inherits="BETTERUI_GamepadMenuEntryCooldownTemplate" tier="MEDIUM"
                    excludeFromResizeToFitExtents="true" />
            </Controls>
        </Control>


        <!-- 
            Template: Simple Menu Entry (Legacy/Basic)
            Purpose: A simpler row template used for non-grid lists (like menu options).
            Structure: Label and Icon only, no extra columns.
        -->
        <Control name="BETTERUI_GamepadMenuEntryTemplate"
            inherits="BETTERUI_GamepadMenuEntryDimensionsTemplate BETTERUI_GamepadMenuEntryLabelSizedTemplate"
            virtual="true">
            <Controls>
                <Label name="$(parent)Label" inherits="BETTERUI_GamepadMenuEntryLabelTemplate" />
                <Texture name="$(parent)Icon" inherits="BETTERUI_GamepadMenuEntryIconTemplate">
                    <Controls>
                        <Label name="$(parent)StackCount"
                            inherits="ZO_GamepadMenuEntryStackCountTemplate" />
                    </Controls>
                </Texture>
            </Controls>
        </Control>

        <!--
            Template: Banking Currency Transfer Row
            Purpose: Currency action rows (Withdraw/Deposit Gold/Tel Var/AP/Writs) aligned
                     to BetterUI's widened list and typography rather than native 470px gamepad
                     template dimensions.
        -->
        <Control name="BETTERUI_BankCurrencySelectorTemplate"
            inherits="BETTERUI_GamepadMenuEntryDimensionsTemplate BETTERUI_GamepadMenuEntryLabelSizedTemplate"
            virtual="true">
            <Anchor point="TOPLEFT" offsetX="BETTERUI_GAMEPAD_CONTAINER_HORIZ_PADDING" />
            <Dimensions x="BETTERUI_GAMEPAD_DEFAULT_LIST_ENTRY_WIDTH" />
            <Controls>
                <Label name="$(parent)Label" inherits="BETTERUI_GamepadMenuEntryLabelTemplate"
                    font="ZoFontGamepad27">
                    <Anchor point="TOPLEFT" offsetX="44" offsetY="-5" />
                    <Dimensions x="BETTERUI_SUBMENU_LABEL_WIDTH" />
                </Label>
                <Texture name="$(parent)Icon" tier="MEDIUM" inherits="ZO_MultiIcon"
                    excludeFromResizeToFitExtents="true" level="1"
                    pixelRoundingEnabled="true">
                    <Dimensions x="BETTERUI_ICON_SIZE_MEDIUM"
                        y="BETTERUI_ICON_SIZE_MEDIUM" />
                    <Anchor point="CENTER" relativeTo="$(parent)Label"
                        relativePoint="LEFT" offsetX="-16" />
                    <Controls>
                        <Label name="$(parent)StackCount"
                            inherits="ZO_GamepadMenuEntryStackCountTemplate" />
                    </Controls>
                </Texture>
            </Controls>
        </Control>


        <!-- 
            Template: Item Slot Wrapper
            Purpose: Inherits BetterUI_GamepadMenuEntryTemplate and adds a StatusIndicator.
        -->
        <Control name="BETTERUI_GamepadItemEntryTemplate"
            inherits="BETTERUI_GamepadMenuEntryTemplate" virtual="true">
            <Controls>
                <Texture name="$(parent)StatusIndicator"
                    inherits="BETTERUI_GamepadMenuEntryStatusIndicationTemplate" />
            </Controls>
        </Control>

    </Controls>
</GuiXml>
