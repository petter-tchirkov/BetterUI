                            <Anchor point="LEFT"
                                relativeTo="$(parent)ListListScreenCenterIsAlongTopListScreenCenter"
                                offsetX="200" />
                            <Anchor point="RIGHT"
                                relativeTo="$(parent)ListListScreenCenterIsAlongTopListScreenCenter"
                                offsetX="200" />
